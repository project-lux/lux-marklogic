{
  "server-name": "%%mlAppName%%-optic-request-group-2",
  "server-type": "http",
  "enabled": "true",
  "root": "/",
  "port": %%mlRestPortGroup2%%,
  "content-database": "%%tenantContentDatabase%%",
  "modules-database": "%%tenantModulesDatabase%%",
  "authentication": "%%mlAuthentication%%",
  "internal-security": "true",
  "external-security": [],
  "threads": %%mlRestMaxThreadsGroup2%%,
  "max-time-limit": %%mlRestMaxTimeoutGroup2%%,
  "default-time-limit": %%mlRestDefaultTimeoutGroup2%%,
  "url-rewriter": "/MarkLogic/rest-api/rewriter.xml",
  "rewrite-resolves-globally": true,
  "error-handler": "/MarkLogic/rest-api/error-handler.xqy",
  "default-user": "nobody",
  "ssl-min-allow-tls": "TLSv1.2",
  "ssl-hostname": "",
  "ssl-ciphers": "DHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-AES128-GCM-SHA256",
  "ssl-ciphersuites": "TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256:TLS_AES_128_GCM_SHA256",
  "ssl-require-client-certificate": true,
  "ssl-client-issuer-authority-verification": false,
  "ssl-certificate-template": "%%mlAppCertificateName%%"
}
