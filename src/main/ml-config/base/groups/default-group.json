{
  "group-name": "Default",
  "cache-sizing": "manual",
  "retry-timeout": 10,
  "compressed-tree-cache-partitions": %%compressedTreeCachePartitions%%,
  "compressed-tree-cache-size": %%compressedTreeCacheSizeMb%%,
  "expanded-tree-cache-partitions": %%expandedTreeCachePartitions%%,
  "expanded-tree-cache-size": %%expandedTreeCacheSizeMb%%,
  "list-cache-partitions": %%listCachePartitions%%,
  "list-cache-size": %%listCacheSizeMb%%,
  "triple-cache-partitions": %%tripleCachePartitions%%,
  "triple-cache-size": %%tripleCacheSizeMb%%,
  "triple-cache-timeout": %%tripleCacheTimeoutSeconds%%,
  "triple-value-cache-partitions": %%tripleValueCachePartitions%%,
  "triple-value-cache-size": %%tripleValueCacheSizeMb%%,
  "triple-value-cache-timeout": %%tripleValueCacheTimeoutSeconds%%,
  "file-log-level": "%%fileLogLevel%%",
  "keep-log-files": %%keepLogFiles%%,
  "events-activated": true,
  "event": ["LuxFacets", "LuxNamedProfiles", "LuxSearch", "LuxRelatedList", "v8 delay timeout"],
  "metering-enabled": true,
  "performance-metering-enabled": true,
  "meters-database": "Meters",
  "performance-metering-period": 60,
  "performance-metering-retain-raw": 14,
  "performance-metering-retain-hourly": 30,
  "performance-metering-retain-daily": 90
}
