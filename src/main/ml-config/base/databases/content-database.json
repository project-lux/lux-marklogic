{
  "database-name": "%%DATABASE%%",
  "schema-database": "%%SCHEMAS_DATABASE%%",
  "preload-mapped-data": true,
  "index-detection": "none",
  "database-backup": [
    {
      "backup-enabled": %%backupEnabled%%,
      "backup-directory": "%%backupBasePath%%/%%DATABASE%%",
      "backup-type": "daily",
      "backup-period": 1,
      "backup-start-time": "05:00:00",
      "max-backups": 1,
      "backup-security-database": false,
      "backup-schemas-database": true,
      "backup-triggers-database": true,
      "include-replicas": false,
      "incremental-backup": true,
      "journal-archiving": false,
      "journal-archive-path": "",
      "journal-archive-lag-limit": 15
    },
    {
      "backup-enabled": %%backupEnabled%%,
      "backup-directory": "%%backupBasePath%%/%%DATABASE%%",
      "backup-type": "weekly",
      "backup-period": 1,
      "backup-day": ["sunday"],
      "backup-start-time": "02:00:00",
      "max-backups": 3,
      "backup-security-database": false,
      "backup-schemas-database": true,
      "backup-triggers-database": true,
      "include-replicas": false,
      "incremental-backup": false,
      "journal-archiving": false,
      "journal-archive-path": "",
      "journal-archive-lag-limit": 15
    }
  ],
  "geospatial-path-index": [
    {
      "path-expression": "/indexedProperties/defined_by_point",
      "coordinate-system": "wgs84",
      "point-format": "point",
      "range-value-positions": true,
      "invalid-values": "reject"
    }
  ],
  "geospatial-region-path-index": [
    {
      "path-expression": "/json[type=\"Place\"]/defined_by",
      "coordinate-system": "wgs84",
      "units": "miles",
      "geohash-precision": 2,
      "invalid-values": "ignore"
    }
  ]
  @@contentDatabaseConfGenerated@@
}
